rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products: anyone can read, admin-only writes
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deals: anyone can read, admin-only writes
    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: secure access with field validation
    match /orders/{orderId} {
      // Single-document read: allowed for anyone who knows the order ID.
      // Order IDs are cryptographic UUIDs — unguessable.
      allow get: if true;

      // Collection queries: admin can list all, authenticated users can query their own
      allow list: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);

      // Create: require auth (userId must match) or allow guest with userId='guest'.
      // Validate required fields and basic sanity checks.
      allow create: if validOrderCreate();

      // Delete: admin only
      allow delete: if isAdmin();

      // Update: admin can update anything (status changes),
      // order owner can ONLY add a review (no other fields)
      allow update: if isAdmin()
        || (request.auth != null
            && resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['review']));
    }

    // Users: read/write own document only, cannot escalate role
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;
    }

    // Settings: anyone can read (restaurant info), admin-only writes
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo codes: only admin can list all codes.
    // Customers can query by code (get) to validate — they need to know the code.
    match /promoCodes/{codeId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Helper functions ---

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function validOrderCreate() {
      let d = request.resource.data;
      return (
        // Auth: signed-in user must match userId, or guest
        (
          (request.auth != null && d.userId == request.auth.uid)
          || (request.auth == null && d.userId == 'guest')
        )
        // Required fields and types
        && d.total is number
        && d.total > 0
        && d.subtotal is number
        && d.subtotal > 0
        && d.tax is number
        && d.tax >= 0
        && d.deliveryFee is number
        && d.deliveryFee >= 0
        && d.items is list
        && d.items.size() > 0
        && d.items.size() <= 50
        && d.address is string
        && d.address.size() > 0
        && d.address.size() <= 500
        && d.phone is string
        && d.phone.size() >= 10
        && d.phone.size() <= 20
        // Promo discount sanity: must be non-negative and not exceed subtotal
        && d.promoDiscount is number
        && d.promoDiscount >= 0
        && d.promoDiscount <= d.subtotal
        // Verify total consistency: total must equal subtotal + tax + deliveryFee - promoDiscount
        && d.total == d.subtotal + d.tax + d.deliveryFee - d.promoDiscount
        // Status fields set by client must be correct
        && d.status == 'confirmed'
      );
    }
  }
}
