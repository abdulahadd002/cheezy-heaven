rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products: anyone can read, admin-only writes
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deals: anyone can read, admin-only writes
    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: anyone can create, anyone can read (IDs are unguessable),
    // admins can update/delete, order owner can add a review
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (request.auth != null
            && resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['review']));
    }

    // Users: read/write own document only, cannot escalate role
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;
    }

    // Settings: anyone can read, admin-only writes
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo codes: anyone can read (to validate), admin-only writes
    match /promoCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
